@code {
    [Parameter, EditorRequired]
    public bool IsOpen { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<bool> Close { get; set; }

    [Parameter]
    public bool ForceRender { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public Func<Task> Search { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool IsApproval { get; set; } = false;

    [Parameter]
    public bool IsReject { get; set; } = false;

    [Parameter]
    public bool IsYosan { get; set; } = false;

    [Parameter]
    public bool IsFilter { get; set; } = false;

    private string GetGridClass()
    {
        string gridcss = "grid-rows-[auto_1fr] grid gap-y-6 overflow-auto";

        if (IsApproval)
        {
            gridcss = "overflow-auto";
        }
        if (IsFilter)
        {
            gridcss = "grid-rows-[auto] grid overflow-scroll";
        }
        if (IsYosan)
        {
            gridcss = "grid-rows-[auto_1fr] grid gap-y-4 overflow-auto";
        }

        return gridcss;
    }
