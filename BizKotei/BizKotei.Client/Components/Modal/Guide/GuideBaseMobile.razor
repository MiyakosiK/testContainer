@* @inject IJSRuntime JSRuntime *@

@* ガイド部分以外をタップすると閉じる *@
<div class="fixed inset-0 z-[90] h-dvh w-dvw @(IsOpen ? "block" : "hidden")" onclick=@Close></div>
@* ガイドOpen時に後ろを暗くする透過背景 transitionを使うため、↑と一緒にできない *@
<div class="pointer-events-none fixed inset-0 h-dvh w-dvw bg-zinc-300 transition-opacity duration-200 ease-in-out @(IsOpen ? "opacity-20" : "opacity-0")"></div>
@* ガイド部分本体 *@
<div class="fixed top-[72px] left-0 z-[90] h-[calc(100dvh-72px)] w-full overflow-hidden rounded-t-xl transition-transform duration-500 ease-in-out @(IsOpen ? "" : "translate-y-[100dvh]")">
    @* スワイプするナビゲーションバー　はお蔵入り *@
    @* <div id="@barId" class="flex h-6 w-full items-center justify-center border border-white bg-white">
    <div class="h-1 w-9 rounded-xs border border-zinc-400 bg-zinc-400"></div>
    </div> *@

    <div class="h-full border border-white bg-white">
        <div class="relative flex h-9 items-center justify-center pt-2">
            @* 閉じるボタン *@
            <button type="button" class="absolute top-2 left-0 flex h-7 w-7 items-center justify-center" onclick=@Close>
                <div class="absolute h-5 w-0.5 origin-center rotate-45 transform bg-black"></div>
                <div class="absolute h-5 w-0.5 origin-center -rotate-45 transform bg-black"></div>
            </button>
            <label class="min-w-fit text-lg font-semibold">@Title</label>
            @if (!IsApproval || IsReject)
            {
                @* 検索 / 確定ボタン *@
                <div class="absolute top-2 right-0 z-[90] mr-2 flex">
                    <button type="button" class="h-7 w-24 rounded-md bg-blue-700 text-left text-base text-white hover:bg-blue-600" @onclick="@(() => Search())">
                        <div class="flex flex-row items-center justify-center">
                            @if (!IsApproval && !IsYosan)
                            {
                                <img src="/images/modalsearch.png" class="h-3.5" />
                            }
                            <div class="p-0.5">@(IsApproval ? "確　定" : IsYosan ? "表　示" : "検索")</div>
                        </div>
                    </button>
                </div>
            }            
        </div>
        <div class="h-[calc(100%-36px)] @GetGridClass() px-1 pt-6">
            @ChildContent
        </div>
    </div>
</div>

