<div class="relative grid max-w-[80dvw] auto-cols-max grid-cols-[minmax(max-content,60px)_1fr] items-center gap-2 @($"{(IsYosan ? "pr-4" : "pr-28")}")">
    @ChildContent
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool IsYosan { get; set; } = false;
}
