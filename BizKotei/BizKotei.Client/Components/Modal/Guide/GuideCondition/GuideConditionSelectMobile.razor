
<label class="p-1">@Name</label>
<InputFieldSelect SelectItems="@SelectItems" IsSelectRequired="@IsRequired" @bind-InputValue="@Value" OnInput="OnValueChange" IsMobileGuide="true" WidthClass="w-full" HeightClass="h-7" />


@code {
    [Parameter, EditorRequired]
    public string? Name { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter, EditorRequired]
    public Dictionary<string, string>? SelectItems { get; set; }

    [Parameter]
    public bool IsRequired { get; set; }

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    private async Task OnValueChange(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}
