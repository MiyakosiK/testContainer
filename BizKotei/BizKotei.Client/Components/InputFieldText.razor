<div class="relative @GetWidthClass()">
    <InputFieldBase Type="InputFieldBase.InputType.Text"
    @bind-InputValue="@InputValue"
    IsTextRight="@IsTextRight"
    IsInvalid="@IsInvalid"
    IsDisabled="@IsDisabled"
    IsMobileGuide="@IsMobileGuide"
    HeightClass="@GetHeightClass()"
    WidthClass="@GetWidthClass()"
    Attributes="@Attributes"
    MaxLength="@MaxLength"
    Placeholder="@Placeholder"
    IsNoTabFocus="@IsNoTabFocus"
    OnInput="OnInputHandler"
    OnKeyDown="OnKeyDownHandler" />

    @if (IsEnableClearButton)
    {
        <button tabindex="-1" type="button" @onclick="@ClearInputValue" class="@(InputValue.IsNullOrEmpty() ? "invisible" : "visible") @GetHeightClass() absolute top-0 right-0 flex aspect-square items-center justify-center text-xl">
			×
        </button>
    }
</div>

@code {
    /// <summary>
    /// バインドしたい場合はパラメータを渡すのではなく「@bind-InputValue="@hoge"」としてください
    /// </summary>
    [Parameter]
    public string? InputValue { get; set; }

    /// <summary>
    /// 入力テキストを右寄せにするかどうか
    /// </summary>
    [Parameter]
    public bool IsTextRight { get; set; }

    /// <summary>
    /// バリデーションエラー等の場合true
    /// 枠や背景を赤にします
    /// </summary>
    [Parameter]
    public bool IsInvalid { get; set; }

    /// <summary>
    /// 入力不可の場合true
    /// 枠や背景をグレーにします
    /// </summary>
    [Parameter]
    public bool IsDisabled { get; set; }

    /// <summary>
    /// スマホ版のガイドでtrueにする
    /// フォーカスアウト時の背景を薄い青にする
    /// </summary>
    [Parameter]
    public bool IsMobileGuide { get; set; }

    /// <summary>
    /// 高さ関係のclassをオーバーライドします
    /// 指定しなければデフォルト値
    /// </summary>
    [Parameter]
    public string? HeightClass { get; set; }

    /// <summary>
    /// 幅関係のclassをオーバーライドします
    /// 指定しなければデフォルト値
    /// </summary>
    [Parameter]
    public string? WidthClass { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? Attributes { get; set; }

    [Parameter]
    public int? MaxLength { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// trueならタブキーでのフォーカス遷移をしない
    /// </summary>
    [Parameter]
    public bool IsNoTabFocus { get; set; }

    /// <summary>
    /// 入力欄の右側にクリアボタンを表示する
    /// </summary>
    [Parameter]
    public bool IsEnableClearButton { get; set; }

    [Parameter]
    public EventCallback<string> InputValueChanged { get; set; }

    /// <summary>
    /// @oninputの代わりに使ってください
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnInput { get; set; }

    /// <summary>
    /// @onkeydownの代わりに使ってください
    /// </summary>
    [Parameter]
    public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }

    /// <summary>
    /// oninput発生時の処理
    /// </summary>
    /// <param name="e"></param>
    /// <returns></returns>
    private async Task OnInputHandler(ChangeEventArgs e)
    {
        InputValue = e.Value?.ToString();
        await InputValueChanged.InvokeAsync(InputValue);  // 入力値の変更を親コンポーネントに通知
        await OnInput.InvokeAsync(e);  // 親コンポーネントでoninputをハンドリングするためにコールバック
    }

    /// <summary>
    /// onkeydown発生時の処理
    /// </summary>
    /// <param name="e"></param>
    /// <returns></returns>
    private async Task OnKeyDownHandler(KeyboardEventArgs e)
    {
        await OnKeyDown.InvokeAsync(e);  // 親コンポーネントでonkeydownをハンドリングするためにコールバック
    }

    private string GetHeightClass()
    {
        // デフォルト値はPC版ガイドの検索条件
        return HeightClass.IsNullOrEmpty() ? "h-6" : HeightClass;
    }

    private string GetWidthClass()
    {
        // デフォルト値はPC版ガイドの検索条件
        return WidthClass.IsNullOrEmpty() ? "w-96" : WidthClass;
    }

    private async Task ClearInputValue()
    {
        InputValue = null;
        await InputValueChanged.InvokeAsync(InputValue);  // 入力値の変更を親コンポーネントに通知
        await OnInput.InvokeAsync();  // 親コンポーネントでoninputをハンドリングするためにコールバック
    }
}
